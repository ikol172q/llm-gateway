# =============================================================
# 环境变量 — 复制为 .env 并填入你的 API Key
# =============================================================

# LiteLLM 代理访问密钥 (随便设一个，用于保护你的代理)
LITELLM_MASTER_KEY=sk-your-secret-key-here

# --- 云端 API Keys (两个都填上效果最好) ---

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Together.ai (跑 Qwen3 235B) — https://api.together.ai/settings/api-keys
TOGETHERAI_API_KEY=

# Anthropic (备用，按需) — https://console.anthropic.com/
# ANTHROPIC_API_KEY=
